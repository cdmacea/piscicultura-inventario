# Copia este archivo como ".env" y ajusta los valores para tu entorno.
# Todas las variables tienen un valor por defecto igual al usado en desarrollo
# (ver docker-compose.yml y backend/src/main/resources/application.yml),
# así que nada se rompe si no defines este archivo.

# --- PostgreSQL ---
POSTGRES_PASSWORD=changeme-local-dev
DB_HOST=localhost
DB_PORT=5432
DB_NAME=piscicultura
DB_USERNAME=postgres
DB_PASSWORD=changeme-local-dev

# --- pgAdmin (solo si usas docker-compose) ---
PGADMIN_PASSWORD=changeme-local-dev

# --- Backend: acceso a la aplicación ---
# Usuario único de la app (no hay gestión de roles/usuarios en base de datos).
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme-local-dev
# Cambia esto en cualquier entorno que no sea tu máquina local.
JWT_SECRET=cambia-este-secreto-en-produccion-minimo-32-caracteres
JWT_EXPIRATION_MINUTES=480
